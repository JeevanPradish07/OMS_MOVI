# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/owms
# Production example:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/owms?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:5173
# Production example:
# CLIENT_URL=https://owms.vercel.app,https://owms.netlify.app

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=10

# ─── Cloudinary (required for file uploads) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
